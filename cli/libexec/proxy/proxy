#!/usr/bin/env bash
set -euo pipefail

# shellcheck source=../../lib/logging.bash
source "$SCT_LIBDIR/logging.bash"
# shellcheck source=../../lib/require.bash
source "$SCT_LIBDIR/require.bash"
# shellcheck source=../../lib/path.bash
source "$SCT_LIBDIR/path.bash"

# Opens the mitmproxy console (TUI) for interactive traffic inspection.
# Replaces the web UI (mitmweb) with the console interface. The WireGuard
# tunnel is briefly interrupted while switching modes and reconnects
# automatically. On exit (or Ctrl+C), the web UI is restored.
proxy() {
	require docker
	require yq

	_proxy_compose_file="$(find_compose_file)"
	_proxy_override=$(mktemp "${TMPDIR:-/tmp}/sandcat-proxy-XXXXXX")

	_proxy_restored=false
	_proxy_switched=false
	_proxy_restore() {
		if [[ "$_proxy_restored" == "true" ]]; then
			return
		fi
		_proxy_restored=true

		rm -f "$_proxy_override"
		if [[ "$_proxy_switched" == "true" ]]; then
			echo "Restoring proxy (web mode)..." | info
			if ! docker compose -f "$_proxy_compose_file" up -d --force-recreate mitmproxy; then
				echo "Failed to restore mitmproxy web mode." | warning
			fi
			if ! docker compose -f "$_proxy_compose_file" up -d --force-recreate wg-client; then
				echo "Failed to restart wg-client." | warning
			fi
		fi
	}
	trap _proxy_restore EXIT

	# Build a YAML override file with the command as a properly encoded list.
	# Start with the base args, then append user args one at a time via yq
	# to ensure correct YAML encoding of special characters.
	yq -n -o yaml '
		.services.mitmproxy.command = ["mitmproxy", "--mode", "wireguard", "-s", "/scripts/mitmproxy_addon.py"] |
		.services.mitmproxy.stdin_open = true |
		.services.mitmproxy.tty = true
	' > "$_proxy_override"
	local arg
	for arg in "$@"; do
		arg="$arg" yq -i '.services.mitmproxy.command += [strenv(arg)]' "$_proxy_override"
	done

	echo "Switching proxy to console mode..." | info
	_proxy_switched=true

	# Run mitmproxy TUI in the foreground so the TTY is properly connected.
	# --attach mitmproxy: only attach stdin/stdout to mitmproxy (not wg-client).
	# --abort-on-container-exit: stop everything when the TUI exits (user presses 'q').
	local console_exit=0
	docker compose -f "$_proxy_compose_file" -f "$_proxy_override" \
		up --force-recreate --attach mitmproxy --abort-on-container-exit \
		mitmproxy wg-client || console_exit=$?

	_proxy_restore
	trap - EXIT
	return "$console_exit"
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]
then
	proxy "$@"
fi
