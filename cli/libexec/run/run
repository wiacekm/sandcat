#!/usr/bin/env bash
set -euo pipefail

# shellcheck source=../../lib/require.bash
source "$SCT_LIBDIR/require.bash"
# shellcheck source=../../lib/path.bash
source "$SCT_LIBDIR/path.bash"

# Run a command in the agent container.
# Starts dependencies, runs the command, then tears everything down.
# Options before '--' are passed to docker compose run (e.g. --build).
# Arguments after '--' (or all args if no '--') are the command to run.
run() {
	require docker

	local compose_file
	compose_file="$(find_compose_file)"

	local -a run_opts=()
	while [[ $# -gt 0 ]]; do
		case $1 in
		--)
			shift
			break
			;;
		--build)
			run_opts+=("$1")
			shift
			;;
		*)
			break
			;;
		esac
	done

	local rc=0
	docker compose -f "$compose_file" run --rm "${run_opts[@]+"${run_opts[@]}"}" agent "${1-bash}" "${@:2}" || rc=$?
	docker compose -f "$compose_file" down
	return "$rc"
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]
then
	run "$@"
fi
