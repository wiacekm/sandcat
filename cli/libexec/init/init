# Returns the user settings template path for a selected agent.
# Args:
#   $1 - Agent name (claude, cursor)
user_settings_template_path() {
	local agent=${1:-claude}
	local template="$SCT_TEMPLATEDIR/settings-user-${agent}.json"
	if [[ ! -f "$template" ]]; then
		echo "Missing user settings template for agent '$agent': $template" | error
		return 1
	fi
	echo "$template"
}

# Creates ~/.config/sandcat/settings.json if it doesn't already exist.
# Derives git identity from the host's git config.
# Args:
#   $1 - Agent name (optional, defaults to claude)
create_user_settings() {
	local agent=${1:-claude}
	local user_settings_dir
	user_settings_dir="$(sct_home)"
	local user_settings="$user_settings_dir/settings.json"

	if [[ -f "$user_settings" ]]; then
		return
	fi

	mkdir -p "$user_settings_dir"
	cp "$(user_settings_template_path "$agent")" "$user_settings"

	# Derive git identity from host config
	local git_name git_email
	git_name=$(git config --global user.name 2>/dev/null || echo "")
	git_email=$(git config --global user.email 2>/dev/null || echo "")

	git_name="${git_name:-Your Name}" git_email="${git_email:-you@example.com}" \
		yq -i -o json '
			.env.GIT_USER_NAME = env(git_name) |
			.env.GIT_USER_EMAIL = env(git_email)
		' "$user_settings"
}

# Ensures Cursor-specific defaults exist in an already-created user settings file
# without overriding user-provided values.
ensure_cursor_user_settings_defaults() {
	local user_settings
	user_settings="$(sct_home)/settings.json"

	if [[ ! -f "$user_settings" ]]; then
		return
	fi

	yq -i -o json '
		.env = (.env // {}) |
		.secrets = (.secrets // {}) |
		.secrets.CURSOR_API_KEY = (.secrets.CURSOR_API_KEY // {"value": "", "hosts": []}) |
		.secrets.CURSOR_API_KEY.hosts = (
			(.secrets.CURSOR_API_KEY.hosts // []) +
			["api.cursor.sh", "api2.cursor.sh", "*.cursor.sh", "*.cursor.com"]
			| unique
		)
	' "$user_settings"
}

# Adds op_service_account_token field to user settings if not already present.
add_op_token_to_user_settings() {
	local user_settings
	user_settings="$(sct_home)/settings.json"

	if [[ ! -f "$user_settings" ]]; then
		return
	fi

	# Add the field only if it doesn't exist yet
	if ! yq -e '.op_service_account_token' "$user_settings" &>/dev/null; then
		yq -i -o json '.op_service_account_token = ""' "$user_settings"
	fi
}

# Initializes sandcat for a project.
# Prompts for any options not provided via flags.
# Args:
#   --agent - Agent type (claude, cursor)
#   --ide - IDE for devcontainer mode (vscode, jetbrains, none)
#   --name - Project name for Docker Compose
#   --path - Project directory path
#   --stacks - Comma-separated list of development stacks (node,python,java,...)
#   --proxy - Proxy UI mode: web (default) or tui
#   --1password - Enable 1Password integration for secrets (no value needed)
#   --features - Comma-separated list of optional features (tui,1password)
init() {
	require yq

	local name=""
	local project_path=""
	local agent=""
	local ide=""
	local stacks_csv=""
	local stacks_provided=false
	local proxy_mode=""
	local onepassword=""
	local features_csv=""
	local features_provided=false

	while [[ $# -gt 0 ]]
	do
		case $1 in
		--name|--path|--agent|--ide|--stacks|--proxy|--features)
			if [[ $# -lt 2 ]]; then
				echo "Option $1 requires a value" | error
				return 1
			fi
			;;
		esac
		case $1 in
		--name)
			name="$2"
			shift 2
			;;
		--path)
			project_path="$2"
			shift 2
			;;
		--agent)
			agent="$2"
			shift 2
			;;
		--ide)
			ide="$2"
			shift 2
			;;
		--stacks)
			stacks_csv="$2"
			stacks_provided=true
			shift 2
			;;
		--proxy)
			proxy_mode="$2"
			shift 2
			;;
		--1password)
			onepassword="true"
			features_provided=true
			shift 1
			;;
		--features)
			features_csv="$2"
			features_provided=true
			shift 2
			;;
		*)
			echo "Unknown option: $1" | error
			return 1
			;;
		esac
	done

	if [[ -z "$project_path" ]]
	then
		project_path="."
	fi

	if [[ ! -d "$project_path" ]]
	then
		echo "Directory does not exist: $project_path" | error
		return 1
	fi
	project_path=$(cd "$project_path" && pwd)

	echo "Configuring project at: $project_path" | info

	local default_name
	default_name="$(derive_project_name "$project_path")"
	if [[ -z "$name" ]]
	then
		name=$(read_line "Project name [$default_name]:")
	fi

	local available_agents=()
	read -ra available_agents <<< "$(sct_available_agents)"
	if [[ -z "$agent" ]]
	then
		agent=$(select_option "Select agent:" "${available_agents[@]}")
	elif ! sct_is_valid_agent "$agent"
	then
		echo "Invalid agent: $agent (expected: ${available_agents[*]})" | error
		return 1
	fi

	if [[ -z "$name" ]]
	then
		name="$default_name"
	fi

	local settings_file="$SCT_PROJECT_DIR/settings.json"

	local available_ides=(vscode jetbrains none)
	if [[ -z "$ide" ]]
	then
		ide=$(select_option "Select IDE:" "${available_ides[@]}")
	elif [[ ! " ${available_ides[*]} " =~ [[:space:]]${ide}[[:space:]] ]]
	then
		echo "Invalid IDE: $ide (expected: ${available_ides[*]})" | error
		return 1
	fi

	# Optional features (tui, 1password)
	if [[ "$features_provided" != "true" ]]; then
		local available_features=("tui (mitmproxy console instead of web UI)" 1password)
		local feature_defaults=()

		# Pre-select 1password if user already has a non-empty op token configured
		local existing_settings
		existing_settings="$(sct_home)/settings.json"
		if [[ -f "$existing_settings" ]] && \
		   yq -e '.op_service_account_token // "" | select(. != "")' "$existing_settings" &>/dev/null; then
			feature_defaults=(1password)
		fi

		local feature_prompt="Select optional features (comma-separated numbers, empty for none):"
		if [[ ${#feature_defaults[@]} -gt 0 ]]; then
			feature_prompt="Select optional features (comma-separated numbers, enter for defaults):"
		fi

		local selected_features
		selected_features=$(select_multiple "$feature_prompt" "${available_features[@]}" -- ${feature_defaults[@]+"${feature_defaults[@]}"})
		if [[ -n "$selected_features" ]]; then
			for f in $selected_features; do
				case "$f" in
					tui*) proxy_mode="tui" ;;
					1password) onepassword="true" ;;
				esac
			done
		fi
	else
		# Parse --features flag
		if [[ -n "$features_csv" ]]; then
			local IFS=','
			for f in $features_csv; do
				case "$f" in
					tui) proxy_mode="tui" ;;
					1password) onepassword="true" ;;
					*) echo "Unknown feature: $f (expected: tui, 1password)" | error; return 1 ;;
				esac
			done
		fi
	fi

	# --proxy flag (backwards compat) overrides feature selection
	if [[ -n "$proxy_mode" ]] && [[ "$proxy_mode" != "web" && "$proxy_mode" != "tui" ]]; then
		echo "Invalid proxy mode: $proxy_mode (expected: web, tui)" | error
		return 1
	fi
	: "${proxy_mode:=web}"

	# Stack selection
	local stacks_resolved=""
	if [[ "$stacks_provided" == "true" ]] && [[ -n "$stacks_csv" ]]; then
		local stacks_arr=()
		IFS=',' read -ra stacks_arr <<< "$stacks_csv"
		local errmsg
		if ! errmsg=$(validate_stacks "${stacks_arr[@]}"); then
			echo "$errmsg" | error
			return 1
		fi
		stacks_resolved=$(resolve_stacks "${stacks_arr[@]}")
	elif [[ "$stacks_provided" != "true" ]]; then
		local selected
		selected=$(select_multiple "Select development stacks (comma-separated numbers, empty for none):" "${STACK_NAMES[@]}")
		if [[ -n "$selected" ]]; then
			local stacks_arr=()
			read -ra stacks_arr <<< "$selected"
			stacks_resolved=$(resolve_stacks "${stacks_arr[@]}")
		fi
	fi

	local services=("$agent")
	if [[ "$ide" != "none" ]]
	then
		services+=("$ide")
	fi

	create_user_settings "$agent"
	if [[ "$agent" == "cursor" ]]; then
		ensure_cursor_user_settings_defaults
	fi

	if [[ "$onepassword" == "true" ]]; then
		add_op_token_to_user_settings
	fi

	settings "$project_path/$settings_file" "${services[@]}"
	local devcontainer_args=(
		--settings-file "$settings_file"
		--project-path "$project_path"
		--agent "$agent"
		--ide "$ide"
		--name "$name"
		--stacks "$stacks_resolved"
		--proxy "$proxy_mode"
	)
	if [[ "$onepassword" == "true" ]]; then
		devcontainer_args+=(--1password)
	fi
	devcontainer "${devcontainer_args[@]}"

	# Summary
	echo "" >&2
	echo "Initialization complete." | info
	if [[ -n "$stacks_resolved" ]]; then
		echo "  Stacks:           $stacks_resolved (edit .devcontainer/Dockerfile.app to change versions)" | info
	fi
	echo "  Project settings: $SCT_PROJECT_DIR/settings.json (network rules)" | info
	echo "  User settings:    ~/.config/sandcat/settings.json (git identity, API keys)" | info
	echo "  Devcontainer:     .devcontainer/" | info
	if [[ "$onepassword" == "true" ]]; then
		echo "  1Password:        enabled" | info
	fi
	echo "" >&2
	echo "Next steps:" | info
	echo "  Edit ~/.config/sandcat/settings.json to add your API keys:" | info
	if [[ "$onepassword" == "true" ]]; then
		if [[ "$agent" == "cursor" ]]; then
			echo "    CURSOR_API_KEY     \"op\": \"op://vault/Cursor API Key/credential\"" | info
		else
			echo "    ANTHROPIC_API_KEY  \"op\": \"op://vault/Anthropic API Key/credential\"" | info
		fi
		echo "    GITHUB_TOKEN       \"op\": \"op://vault/GitHub Token/credential\"" | info
		echo "    (adjust vault/item names to match your 1Password setup," | info
		echo "     or use plain values with \"value\": \"sk-ant-...\")" | info
		echo "" >&2
		echo "  1Password setup:" | info
		echo "    1. Create a service account at https://my.1password.com/developer-tools/infrastructure-secrets/serviceaccount/" | info
		echo "    2. Grant it read access to the vault(s) containing your secrets" | info
		echo "    3. Add the token to ~/.config/sandcat/settings.json:" | info
		echo "       \"op_service_account_token\": \"ops_...\"" | info
	else
		echo "    $(sct_agent_api_key_help "$agent")" | info
		echo "    GITHUB_TOKEN       a GitHub personal access token (for git push, gh cli)" | info
	fi
	echo "  Then run: sandcat run, or reopen the project using the dev container" | info
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]
then
	init "$@"
fi
